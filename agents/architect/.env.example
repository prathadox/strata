MANTLE_RPC_URL=https://rpc.mantle.xyz
ARCHITECT_PRIVATE_KEY=0x...
ARCHITECT_DRY_RUN=true
AGENT_EVENT_BUS_ADDRESS=
# Reserved for a future on-chain identity cross-check. Architect's verifier
# currently gates on SCOUT_ADDRESS (env-var compare), not on a registry read.
IDENTITY_REGISTRY_ADDRESS=
# The Scout signer address. When set, the verifier asserts the recovered EIP-191
# signer equals this address in addition to map.publisher.address.
SCOUT_ADDRESS=
LIGHTHOUSE_API_KEY=
# Reserved for a future polling-fallback mode. The live run loop is event-driven
# and does not read this today.
CYCLE_INTERVAL_MS=60000
LOG_LEVEL=info
ARCHITECT_IDENTITY_NFT=ipfs://placeholder
ARCHITECT_HEALTH_PORT=9091

# Optional: enables Task 16's narrative-text layer. Leave blank to ship Architect
# fully deterministic with no LLM in the allocation path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
