MANTLE_RPC_URL=https://rpc.mantle.xyz
SCOUT_PRIVATE_KEY=0x...

# Set SCOUT_DRY_RUN=true to skip the on-chain publishYieldMap step.
# The full off-chain pipeline still runs (ingest, score, sign, pin to Lighthouse).
# When true, AGENT_EVENT_BUS_ADDRESS can be left blank.
SCOUT_DRY_RUN=false
AGENT_EVENT_BUS_ADDRESS=0x...

LIGHTHOUSE_API_KEY=
NANSEN_API_KEY=
# Optional. Preferred source for stable-asset depeg history. Without it, depeg
# history falls back to DefiLlama's keyless coins API.
COINGECKO_API_KEY=
CYCLE_INTERVAL_MS=60000
LOG_LEVEL=info
